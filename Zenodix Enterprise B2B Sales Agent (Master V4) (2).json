    {
      "parameters": {
        "jsCode": "const body = $input.item.json.body || $input.item.json;\nlet binaryData = {};\nlet hasAudio = false;\nlet hasImage = false;\nlet ruta = \"texto\";\n\nif (body.audioBase64) {\n    hasAudio = true;\n    ruta = \"audio\";\n    let bdata = body.audioBase64.includes(',') ? body.audioBase64.split(',')[1] : body.audioBase64;\n    binaryData['audio'] = { data: bdata, mimeType: 'audio/webm', fileName: 'audio.webm' };\n}\n\nif (body.imageBase64) {\n    hasImage = true;\n    ruta = \"imagen\";\n    let idata = body.imageBase64.includes(',') ? body.imageBase64.split(',')[1] : body.imageBase64;\n    binaryData['image'] = { data: idata, mimeType: 'image/jpeg', fileName: 'image.jpg' };\n}\n\nreturn {\n    json: {\n        sessionId: body.sessionId || \"sesion_default\",\n        message: body.message || \"\",\n        hasAudio: hasAudio,\n        hasImage: hasImage,\n        ruta: ruta\n    },\n    binary: Object.keys(binaryData).length > 0 ? binaryData : undefined\n};"
      },
